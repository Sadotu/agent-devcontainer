# Secrets and agent credentials must never be committed.
.env
.env.*
*.token
*.pem
*.key
*credentials*
secrets/

# Agent config/auth dirs (live in container volumes, but never commit copies)
.claude/
.codex/
.gemini/
.config/

# Local noise
*.log
node_modules/

# Dogfood copy dropped in by setup-agents.sh when developing this repo's own
# devcontainer — source of truth is .devcontainer/agents.toml.
/agents.toml

# Dotagents metadata generated during devcontainer setup.
/agents.lock
/.agents/.gitignore
